// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum IncidentStatus {
  PENDING
  IN_PROGRESS
  RESOLVED
}

enum IncidentType {
  ACCIDENT
  FIRE
  MEDICAL
}

enum VehiculeStatus {
  AVAILABLE
  DISPATCHED
  BUSY
  OFFLINE
  EN_ROUTE
  AT_INCIDENT
}

enum VehiculeType {
  AMBULANCE
  FIRE_TRUCK
  POLICE_CAR
  TOW_TRUCK
}

enum AssignmentStatus {
  ASSIGNED
  ACCEPTED
  EN_ROUTE
  ARRIVED
  COMPLETED
  CANCELLED
}

enum Role {
  ADMIN
  USER
}

model User {
  id String @id @default(uuid())
  name String
  email String @unique
  password String
  role Role @default(USER)
  phone String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Incident {
  id        String      @id @default(uuid())
  type      IncidentType
  location  String
  description String
  status    IncidentStatus @default(PENDING)
  latitude Float
  longitude Float
  priority   Int @default(50)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  assignments Assignment[]

}

model Vehicule {
  id String @id @default(uuid())
  name String
  plate String @unique
  type VehiculeType
  status VehiculeStatus @default(AVAILABLE)
  latitude Float
  longitude Float
  trackingEnable Boolean @default(false)
  lastSeen DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  assignments Assignment[]
  telemetries Telemetry[]


}

model Assignment {
  id String @id @default(uuid())
  incidentId String
  vehiculeId String

  incident Incident @relation(fields: [incidentId], references: [id])
  vehicule Vehicule @relation(fields: [vehiculeId], references: [id])

  status AssignmentStatus @default(ASSIGNED)

  assignedAt DateTime @default(now())

  acceptedAt DateTime?

  arrivedAt DateTime?

  completedAt DateTime?

  createdAt DateTime @default(now())
}

model Telemetry {
  id         String   @id @default(uuid())
  vehiculeId String
  latitude   Float
  longitude  Float

  speed      Float?   // velocidade em m/s (da Browser Geolocation API)
  accuracy   Float?   // precisão do GPS em metros
  heading    Float?   // direção em graus (0-360), null se parado

  createdAt  DateTime @default(now())

  vehicule Vehicule @relation(fields: [vehiculeId], references: [id], onDelete: Cascade)

  @@index([vehiculeId])
  @@index([vehiculeId, createdAt])
}

model Auditlog {
  id String @id @default(uuid())
  eventType String
  payload Json
  createdAt DateTime @default(now())
}