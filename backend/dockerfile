# ==============================================================================
# Backend Dockerfile — Produção (multi-stage)
# Compila a aplicação NestJS usando Node.js.
# Imagem final Alpine para segurança e tamanho mínimo.
#
# Build context: backend/
# ==============================================================================

# ---------- Stage 1: Install & Build ----------
FROM node:20-alpine AS build

WORKDIR /app

# Instalar dependências necessárias para compilação/ferramentas nativas (ex: bcrypt)
RUN apk add --no-cache python3 make g++

# Copiar arquivos de manifesto e instalar dependências
COPY package*.json ./
RUN npm install

# Copiar código-fonte, configurações e arquivos do Prisma
COPY tsconfig*.json ./
COPY nest-cli.json ./
COPY prisma ./prisma
COPY prisma.config.ts ./
COPY src ./src

# Gerar o Prisma Client (necessário no build para gerar os tipos no node_modules)
RUN npx prisma generate

# Compilar a aplicação para produção
RUN npm run build

# Remover dependências de desenvolvimento para deixar a pasta node_modules limpa para a produção
RUN npm prune --production

# ---------- Stage 2: Runtime ----------
FROM node:20-alpine

WORKDIR /app

# Copiar dependências de produção e o build compilado do NestJS
COPY --from=build /app/node_modules ./node_modules
COPY --from=build /app/dist ./dist
COPY --from=build /app/package*.json ./
COPY --from=build /app/prisma ./prisma
COPY --from=build /app/prisma.config.ts ./
COPY --from=build /app/tsconfig.json ./
COPY --from=build /app/public ./public

# Instalar o Prisma CLI e compiladores TypeScript em produção para poder rodar migrations (Prisma 7 requer isso)
RUN npm install prisma@7.8.0 ts-node typescript --omit=dev

ENV NODE_ENV=production

EXPOSE 3000

# Executar migrações pendentes e iniciar o servidor NestJS
CMD ["sh", "-c", "npx prisma migrate deploy && node dist/src/main"]
